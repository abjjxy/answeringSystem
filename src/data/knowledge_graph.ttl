@prefix ex: <http://example.org/calligraphy#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# ==========================================
# ONTOLOGY DEFINITIONS
# ==========================================
ex:Person rdf:type rdfs:Class ;
    rdfs:label "人物" ;
    rdfs:comment "篆刻艺术家或印学家" .

ex:School rdf:type rdfs:Class ;
    rdfs:label "流派" ;
    rdfs:comment "篆刻印派或印风流派" .

ex:ScriptStyle rdf:type rdfs:Class ;
    rdfs:label "印风" ;
    rdfs:comment "秦汉印风、拟古印、自然印等篆刻风格" .

ex:Location rdf:type rdfs:Class ;
    rdfs:label "地理位置" ;
    rdfs:comment "人物籍贯或流派活动发源地" .

# Properties
ex:zi rdf:type rdf:Property ;
    rdfs:label "字" ;
    rdfs:domain ex:Person ;
    rdfs:range xsd:string .

ex:hao rdf:type rdf:Property ;
    rdfs:label "号" ;
    rdfs:domain ex:Person ;
    rdfs:range xsd:string .

ex:dynasty rdf:type rdf:Property ;
    rdfs:label "朝代" ;
    rdfs:domain ex:Person ;
    rdfs:range xsd:string .

ex:birthYear rdf:type rdf:Property ;
    rdfs:label "生年" ;
    rdfs:domain ex:Person ;
    rdfs:range xsd:integer .

ex:deathYear rdf:type rdf:Property ;
    rdfs:label "卒年" ;
    rdfs:domain ex:Person ;
    rdfs:range xsd:integer .

ex:father rdf:type rdf:Property ;
    rdfs:label "父亲" ;
    rdfs:domain ex:Person ;
    rdfs:range ex:Person .

ex:child rdf:type rdf:Property ;
    rdfs:label "子女" ;
    rdfs:domain ex:Person ;
    rdfs:range ex:Person .

ex:studentOf rdf:type rdf:Property ;
    rdfs:label "师从" ;
    rdfs:domain ex:Person ;
    rdfs:range ex:Person .

ex:teacherOf rdf:type rdf:Property ;
    rdfs:label "弟子/传人" ;
    rdfs:domain ex:Person ;
    rdfs:range ex:Person .

ex:interactedWith rdf:type rdf:Property ;
    rdfs:label "交游/挚友" ;
    rdfs:domain ex:Person ;
    rdfs:range ex:Person .

ex:founderOf rdf:type rdf:Property ;
    rdfs:label "开创" ;
    rdfs:domain ex:Person ;
    rdfs:range ex:School .

ex:schoolMemberOf rdf:type rdf:Property ;
    rdfs:label "所属流派" ;
    rdfs:domain ex:Person ;
    rdfs:range ex:School .

ex:practicedStyle rdf:type rdf:Property ;
    rdfs:label "擅长艺术风格" ;
    rdfs:domain ex:Person ;
    rdfs:range ex:ScriptStyle .

ex:nativePlace rdf:type rdf:Property ;
    rdfs:label "籍贯" ;
    rdfs:domain ex:Person ;
    rdfs:range ex:Location .

ex:ctextId rdf:type rdf:Property ;
    rdfs:label "ctext ID对齐" ;
    rdfs:domain ex:Person ;
    rdfs:range xsd:string .

ex:cbdbId rdf:type rdf:Property ;
    rdfs:label "CBDB ID对齐" ;
    rdfs:domain ex:Person ;
    rdfs:range xsd:string .

ex:introduction rdf:type rdf:Property ;
    rdfs:label "简介" ;
    rdfs:domain ex:Person ;
    rdfs:range xsd:string .

# ==========================================
# STYLES DEFINITION
# ==========================================
ex:QinHanSeals rdf:type ex:ScriptStyle ; rdfs:label "秦汉印风" .
ex:SealScript rdf:type ex:ScriptStyle ; rdfs:label "篆书" .
ex:ClericalScript rdf:type ex:ScriptStyle ; rdfs:label "隶书" .
ex:StoneDrumScript rdf:type ex:ScriptStyle ; rdfs:label "石鼓文" .

# ==========================================
# LOCATIONS DEFINITION
# ==========================================
ex:Shaoxing rdf:type ex:Location ; rdfs:label "会稽 (浙江绍兴)" .
ex:Suzhou rdf:type ex:Location ; rdfs:label "长洲 (江苏苏州 - 吴门)" .
ex:Hangzhou rdf:type ex:Location ; rdfs:label "钱塘 (浙江杭州)" .
ex:Huizhou rdf:type ex:Location ; rdfs:label "歙县 (安徽徽州)" .
ex:An慶 rdf:type ex:Location ; rdfs:label "怀宁 (安徽安庆 - 完白)" .
ex:ShaoxingMin rdf:type ex:Location ; rdfs:label "绍兴 (浙江)" .
ex:Ningbo rdf:type ex:Location ; rdfs:label "鄞县 (浙江宁波)" .

# ==========================================
# SCHOOLS DEFINITION
# ==========================================
ex:WumenSchool rdf:type ex:School ; rdfs:label "吴门印派" .
ex:XueyuSchool rdf:type ex:School ; rdfs:label "雪渔派 (徽派之祖)" .
ex:SishuiSchool rdf:type ex:School ; rdfs:label "泗水印派" .
ex:LoudongSchool rdf:type ex:School ; rdfs:label "娄东印派" .
ex:XilingSchool rdf:type ex:School ; rdfs:label "西泠印派 (浙派)" .
ex:WanpaiSchool rdf:type ex:School ; rdfs:label "皖派 (邓派)" .

# ==========================================
# CHARACTERS (RDF TRIPLE DATA)
# ==========================================

# 1. 文徵明 (Wen Zhengming) - Father of Wen Peng
ex:WenZhengming rdf:type ex:Person ;
    rdfs:label "文徵明" ;
    ex:zi "征仲" ;
    ex:hao "衡山居士" ;
    ex:dynasty "明" ;
    ex:birthYear 1470 ;
    ex:deathYear 1559 ;
    ex:nativePlace ex:Suzhou ;
    ex:practicedStyle ex:SealScript , ex:ClericalScript ;
    ex:child ex:WenPeng ;
    ex:teacherOf ex:WenPeng ;
    ex:ctextId "728456" ;
    ex:cbdbId "19940" ;
    ex:introduction "文徵明，初字征明，更字征仲，号衡山居士。明代著名书法家、画家、文学家，'吴门四家'之一。诗书画无一不精，行书端雅，小楷极精。其子文彭深受其教，并开创了明清篆刻的新纪元。" .

# 2. 文彭 (Wen Peng) - The core founder of modern seal engraving
ex:WenPeng rdf:type ex:Person ;
    rdfs:label "文彭" ;
    ex:zi "寿承" ;
    ex:hao "三桥" ;
    ex:dynasty "明" ;
    ex:birthYear 1498 ;
    ex:deathYear 1573 ;
    ex:nativePlace ex:Suzhou ;
    ex:father ex:WenZhengming ;
    ex:studentOf ex:WenZhengming ;
    ex:founderOf ex:WumenSchool ;
    ex:schoolMemberOf ex:WumenSchool ;
    ex:teacherOf ex:HeZhen , ex:SuXuan ;
    ex:practicedStyle ex:QinHanSeals , ex:SealScript , ex:ClericalScript ;
    ex:ctextId "728461" ;
    ex:cbdbId "34112" ;
    ex:introduction "文彭，字寿承，号三桥，文徵明长子。国子监博士。工书画，尤精印章，在南京偶然发现青田石（冻石），改用石材治印，从此文人纷纷親自动手刻印，彻底改变了以往文人写篆、工匠刊刻的局面，开创'吴门印派'，尊为'文人篆刻之祖'。" .

# 3. 何震 (He Zhen) - Founder of Xueyu School
ex:HeZhen rdf:type ex:Person ;
    rdfs:label "何震" ;
    ex:zi "主臣" ;
    ex:hao "雪渔" ;
    ex:dynasty "明" ;
    ex:birthYear 1530 ;
    ex:deathYear 1604 ;
    ex:nativePlace ex:Huizhou ;
    ex:studentOf ex:WenPeng ;
    ex:interactedWith ex:WenPeng ;
    ex:founderOf ex:XueyuSchool ;
    ex:schoolMemberOf ex:XueyuSchool ;
    ex:teacherOf ex:SuXuan , ex:ZhuJian ;
    ex:practicedStyle ex:QinHanSeals , ex:SealScript ;
    ex:ctextId "728470" ;
    ex:cbdbId "41334" ;
    ex:introduction "何震，字主臣，号雪渔，徽州人。文彭入室弟子。其印风挺拔刚健，力矫文彭柔媚之弊，首创'急就章'刻法，浑厚苍劲。与文彭并称'文何'，其流派被称为'雪渔派'，为徽门印学之开山。" .

# 4. 苏宣 (Su Xuan) - Sishui School Founder
ex:SuXuan rdf:type ex:Person ;
    rdfs:label "苏宣" ;
    ex:zi "尔宣" ;
    ex:hao "泗水" ;
    ex:dynasty "明" ;
    ex:birthYear 1553 ;
    ex:deathYear 1626 ;
    ex:nativePlace ex:Huizhou ;
    ex:studentOf ex:WenPeng , ex:HeZhen ;
    ex:interactedWith ex:HeZhen ;
    ex:founderOf ex:SishuiSchool ;
    ex:schoolMemberOf ex:SishuiSchool ;
    ex:practicedStyle ex:QinHanSeals , ex:SealScript ;
    ex:ctextId "728473" ;
    ex:cbdbId "41355" ;
    ex:introduction "苏宣，字尔宣，号泗水。明代印章名家。他曾师从文彭与何震，遍读秦汉印玺，融汇文何精髓，创立'泗水印派'。他的章法苍劲稳重，开明代仿汉印之大成。" .

# 5. 朱简 (Zhu Jian) - Scholar of Seal Art
ex:ZhuJian rdf:type ex:Person ;
    rdfs:label "朱简" ;
    ex:zi "修能" ;
    ex:hao "明绿山人" ;
    ex:dynasty "明" ;
    ex:birthYear 1570 ;
    ex:deathYear 1640 ;
    ex:nativePlace ex:Huizhou ;
    ex:studentOf ex:HeZhen ;
    ex:teacherOf ex:ChengSui ;
    ex:practicedStyle ex:QinHanSeals , ex:SealScript ;
    ex:ctextId "728477" ;
    ex:cbdbId "41369" ;
    ex:introduction "朱简，字修能，号明绿山人，徽州人。他是篆刻史上的理论大家，撰写《印章要论》、《印书》，提出著名的'刀法论'。其刀法以碎刀、切刀见长，苍茫多姿，开辟了篆刻技术的新道路。" .

# 6. 程邃 (Cheng Sui)
ex:ChengSui rdf:type ex:Person ;
    rdfs:label "程邃" ;
    ex:zi "穆倩" ;
    ex:hao "垢道人" ;
    ex:dynasty "清" ;
    ex:birthYear 1607 ;
    ex:deathYear 1692 ;
    ex:nativePlace ex:Huizhou ;
    ex:studentOf ex:ZhuJian ;
    ex:practicedStyle ex:QinHanSeals , ex:SealScript ;
    ex:ctextId "728511" ;
    ex:cbdbId "50211" ;
    ex:introduction "程邃，字穆倩，号垢道人，诸生，安徽徽州人。清初著名篆刻家、书法家、画家。他遥承朱简刀法，善用干笔渴墨画山水，篆刻则纯用朱简冲切结合，印学以苍浑质朴、满白见长，世尊为徽派领袖。" .

# 7. 汪关 (Wang Guan) - Loudong School
ex:WangGuan rdf:type ex:Person ;
    rdfs:label "汪关" ;
    ex:zi "东之" ;
    ex:hao "宝印斋" ;
    ex:dynasty "明" ;
    ex:birthYear 1580 ;
    ex:deathYear 1645 ;
    ex:nativePlace ex:Suzhou ;
    ex:founderOf ex:LoudongSchool ;
    ex:schoolMemberOf ex:LoudongSchool ;
    ex:practicedStyle ex:QinHanSeals ;
    ex:ctextId "728485" ;
    ex:cbdbId "41380" ;
    ex:introduction "汪关，原名东阳，字东之，后改名关。因得汉代'汪关'私印，遂改名汪关。他避开何震过于猛厉之风，专精于汉印的平正沉茂，以冲刀精工见长，开创'娄东印派'，对后世工整一路影响深远。" .

# 8. 丁敬 (Ding Jing) - Founder of Zhe School
ex:DingJing rdf:type ex:Person ;
    rdfs:label "丁敬" ;
    ex:zi "敬身" ;
    ex:hao "砚林" ;
    ex:dynasty "清" ;
    rdfs:label "丁敬" ;
    ex:birthYear 1695 ;
    ex:deathYear 1765 ;
    ex:nativePlace ex:Hangzhou ;
    ex:founderOf ex:XilingSchool ;
    ex:schoolMemberOf ex:XilingSchool ;
    ex:teacherOf ex:JiangRen , ex:HuangYi ;
    ex:practicedStyle ex:QinHanSeals , ex:SealScript , ex:ClericalScript ;
    ex:ctextId "728520" ;
    ex:cbdbId "50392" ;
    ex:introduction "丁敬，字敬身，号砚林、两湖居士，浙江钱塘人。清代著名篆刻家、书法家，'西泠八家'之首，浙派印风之鼻祖。他汲取宋元印论并融合秦汉印精髓，独创碎刀涩刻之'切刀法'，开创了风靡百余年的'浙派/西泠印派'。" .

# 9. 黄易 (Huang Yi) - Active Zhe School Master
ex:HuangYi rdf:type ex:Person ;
    rdfs:label "黄易" ;
    ex:zi "大易" ;
    ex:hao "小松" ;
    ex:dynasty "清" ;
    ex:birthYear 1744 ;
    ex:deathYear 1802 ;
    ex:nativePlace ex:Hangzhou ;
    ex:studentOf ex:DingJing ;
    ex:schoolMemberOf ex:XilingSchool ;
    ex:interactedWith ex:DingJing ;
    ex:practicedStyle ex:ClericalScript , ex:QinHanSeals ;
    ex:ctextId "728532" ;
    ex:cbdbId "50412" ;
    ex:introduction "黄易，字大易，号小松，丁敬杰出传人，'西泠八家'之一。他不仅工书画刻印，且致力于访碑，著有《小松访碑图》。其印风严谨，平正中见奇峭，对扩展浙派影响起到了极大的推动作用。" .

# 10. 邓石如 (Deng Shiru) - Wanpai Master and Calligraphy Giant
ex:DengShiru rdf:type ex:Person ;
    rdfs:label "邓石如" ;
    ex:zi "顽伯" ;
    ex:hao "完白山人" ;
    ex:dynasty "清" ;
    ex:birthYear 1743 ;
    ex:deathYear 1805 ;
    ex:nativePlace ex:An慶 ;
    ex:founderOf ex:WanpaiSchool ;
    ex:schoolMemberOf ex:WanpaiSchool ;
    ex:teacherOf ex:WuXizai ;
    ex:practicedStyle ex:SealScript , ex:ClericalScript ;
    ex:ctextId "728551" ;
    ex:cbdbId "50450" ;
    ex:introduction "邓石如，字顽伯，号完白山人，安徽怀宁人。清代中期杰出书法家、篆刻家，'皖派'之祖。其书法篆、隶、真、行、草皆臻神妙，尤以篆书融汇隶书笔意（以隶笔写篆），冠绝清代。他主张'书从印入，印从书出'，打破了汉印局限，对近代书风、印学产生革命性颠覆。" .

# 11. 吴熙载 (Wu Xizai) - Devoted student of Deng Shiru
ex:WuXizai rdf:type ex:Person ;
    rdfs:label "吴熙载" ;
    ex:zi "让之" ;
    ex:hao "晚学居士" ;
    ex:dynasty "清" ;
    ex:birthYear 1799 ;
    ex:deathYear 1870 ;
    ex:nativePlace ex:An慶 ; # 扬州
    ex:studentOf ex:DengShiru ;
    ex:schoolMemberOf ex:WanpaiSchool ;
    ex:practicedStyle ex:SealScript , ex:QinHanSeals ;
    ex:ctextId "728560" ;
    ex:cbdbId "50490" ;
    ex:introduction "吴熙载，原名廷飏，字熙载，后以字行，改字让之，晚号晚学居士。他是邓石如的登堂入室弟子，忠实继承并发扬了邓石如'书从印入'的思想。其篆刻活泼流畅，刀法精妙神速，世称'让之印风'，把皖派艺术推向极致。" .

# 12. 赵之谦 (Zhao Zhiqian) - Modern Pioneer of Stele Script & Seals
ex:ZhaoZhiqian rdf:type ex:Person ;
    rdfs:label "赵之谦" ;
    ex:zi "益甫" ;
    ex:hao "悲盦" ;
    ex:dynasty "清" ;
    ex:birthYear 1829 ;
    ex:deathYear 1884 ;
    ex:nativePlace ex:ShaoxingMin ;
    ex:practicedStyle ex:SealScript , ex:ClericalScript ;
    ex:ctextId "728575" ;
    ex:cbdbId "50523" ;
    ex:introduction "赵之谦，字益甫，号悲盦，浙江绍兴人。晚清杰出书画家、篆刻家。他开创性地将魏碑体与隶篆书法结合，并提倡'印外求印'，将战国诏版、汉镜、钱币等多重文字形式融入篆刻，在艺术思想上，彻底冲破了由浙派、皖派主导的藩篱。" .

# 13. 吴昌硕 (Wu Changshuo) - The Grandmaster of Stone Drum calligraphy
ex:WuChangshuo rdf:type ex:Person ;
    rdfs:label "吴昌硕" ;
    ex:zi "俊卿" ;
    ex:hao "缶庐" ;
    ex:dynasty "晚清 / 民国" ;
    ex:birthYear 1844 ;
    ex:deathYear 1927 ;
    ex:nativePlace ex:Ningbo ; # 浙江吉安县 (湖州)
    ex:interactedWith ex:ZhaoZhiqian ;
    ex:schoolMemberOf ex:XilingSchool ;
    ex:practicedStyle ex:StoneDrumScript , ex:QinHanSeals ;
    ex:ctextId "728590" ;
    ex:cbdbId "50612" ;
    ex:introduction "吴昌硕，浙江吉安人，字俊卿，号缶庐，西泠印社首任社长。晚清清末集诗、书、画、印于一身的艺术巨匠。他将石鼓文笔意融入篆刻、行书和写意大花卉之中，笔墨沉雄浑厚，其篆刻将切刀与冲刀结合，并独创击残、风化仿古效果，开启近代美学新风尚。" .